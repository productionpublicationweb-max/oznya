{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/daily-reminder",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/backup",
      "schedule": "0 0 * * *"
    }
  ],
  "build": {
    "env": {
      "FORCE_CACHE_BUST": "v6-2026-03-04"
    }
  }
}
